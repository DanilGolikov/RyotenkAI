# MLOps Pipeline Secrets Template
# Copy this file to secrets.env and fill in your values
# ⚠️ NEVER commit secrets.env to git!

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# RunPod API key - Get from: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=your_runpod_api_key_here

# HuggingFace token - Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# =============================================================================
# OPTIONAL: MLflow HTTPS / TLS
# =============================================================================

# Custom CA bundle for HTTPS MLflow servers (for REQUESTS/urllib verification)
# REQUESTS_CA_BUNDLE=/absolute/path/to/mlflow-ca.pem
# SSL_CERT_FILE=/absolute/path/to/mlflow-ca.pem

# =============================================================================
# OPTIONAL: Evaluation
# =============================================================================

# Cerebras API key for LLM-as-a-judge evaluation plugin
# EVAL_CEREBRAS_API_KEY=your_cerebras_api_key_here
