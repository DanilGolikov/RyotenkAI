# Dev-profile port pinning for the hermetic stack.
#
# Read by tests._harness.stack.orchestrator's CLI when invoked via
# `make start-stack` / `make stop-stack` / `make state-dump`. Tests do
# NOT read this file — they boot per-test Stacks on ephemeral ports
# allocated via tests._harness.stack.ports.allocate_port_block.
#
# Override by exporting the env vars in your shell.

RYOTENKAI_STACK_RUNPOD_PORT=18091
RYOTENKAI_STACK_MLFLOW_PORT=18092
RYOTENKAI_STACK_VLLM_PORT=18093
RYOTENKAI_STACK_HF_HUB_PORT=18094
RYOTENKAI_STACK_CONTROL_PORT=18080
RYOTENKAI_STACK_RUNNER_PORT=18081
