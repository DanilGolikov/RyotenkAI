{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "--port", "5183"],
      "cwd": "web",
      "port": 5183,
      "env": {
        "RYOTENKAI_API_HOST": "127.0.0.1",
        "RYOTENKAI_API_PORT": "8010"
      }
    },
    {
      "name": "web-backend",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "src.main", "serve", "--host", "127.0.0.1", "--port", "8010", "--runs-dir", "runs", "--cors-origins", "http://localhost:5183"],
      "port": 8010
    }
  ]
}
